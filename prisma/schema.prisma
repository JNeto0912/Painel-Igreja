generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Novo modelo para representar cada igreja
model Igreja {
  id        Int       @id @default(autoincrement())
  nome      String    // Nome da igreja (ex: "Igreja Central", "Filial Norte")
  slug      String    @unique // Um identificador único para a URL ou sistema (ex: "central", "filial-norte")
  endereco  String?   // Endereço da igreja (opcional)
  cidade    String?   // Cidade da igreja (opcional)
  estado    String?   // Estado da igreja (opcional)
  cep       String?   // CEP da igreja (opcional)
  telefone  String?   // Telefone da igreja (opcional)
  email     String?   // E-mail da igreja (opcional)
  ativo     Boolean   @default(true) // Se a igreja está ativa no sistema
  criadoEm  DateTime  @default(now())

  // Relações com outros modelos
  usuarios    Usuario[]
  avisos      Aviso[]
  membros     Membro[]
  servicos    Servico[]
  voluntarios Voluntario[]
}

model Aviso {
  id         Int      @id @default(autoincrement())
  titulo     String
  descricao  String?
  imagemUrl  String
  dataInicio DateTime
  dataFim    DateTime
  ordem      Int      @default(0)
  ativo      Boolean  @default(true)
  criadoEm   DateTime @default(now())

  // Adiciona a relação com Igreja
  igrejaId   Int
  igreja     Igreja   @relation(fields: [igrejaId], references: [id])
}

model Membro {
  id             Int      @id @default(autoincrement())
  nome           String
  dataNascimento DateTime
  fotoUrl        String?
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())

  // Adiciona a relação com Igreja
  igrejaId       Int
  igreja         Igreja   @relation(fields: [igrejaId], references: [id])
}

model TipoServico {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  servicos Servico[]
}

model Servico {
  id           Int         @id @default(autoincrement())
  nome         String
  tipoId       Int
  tipo         TipoServico @relation(fields: [tipoId], references: [id])
  descricao    String?
  telefone     String
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())

  // Adiciona a relação com Igreja
  igrejaId     Int
  igreja       Igreja      @relation(fields: [igrejaId], references: [id])
}

model VoluntarioArea {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  voluntarios Voluntario[]
}

model Voluntario {
  id         Int             @id @default(autoincrement())
  nome       String
  areaId     Int
  area       VoluntarioArea  @relation(fields: [areaId], references: [id])
  dons       String?
  telefone   String
  email      String?
  disponivel Boolean         @default(true)
  criadoEm   DateTime        @default(now())

  // Adiciona a relação com Igreja
  igrejaId   Int
  igreja     Igreja          @relation(fields: [igrejaId], references: [id])
}

model Usuario {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  senha     String
  telefone  String?  // Mantive o telefone, mas se não for usar, pode remover
  aprovado  Boolean  @default(false)
  admin     Boolean  @default(false)
  criadoEm  DateTime @default(now())

  // Adiciona a relação com Igreja
  igrejaId  Int
  igreja    Igreja   @relation(fields: [igrejaId], references: [id])
}