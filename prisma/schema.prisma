generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Aviso {
  id         Int      @id @default(autoincrement())
  titulo     String
  descricao  String?
  imagemUrl  String
  dataInicio DateTime
  dataFim    DateTime
  ordem      Int      @default(0)
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Membro {
  id             Int      @id @default(autoincrement())
  nome           String
  dataNascimento DateTime
  fotoUrl        String?
  ativo          Boolean  @default(true)
  criadoEm      DateTime @default(now())
}

model TipoServico {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  servicos Servico[]
}

model Servico {
  id           Int         @id @default(autoincrement())
  nome         String
  tipoId       Int
  tipo         TipoServico @relation(fields: [tipoId], references: [id])
  descricao    String?
  telefone     String
  ativo        Boolean     @default(true)
  criadoEm    DateTime    @default(now())
}

model VoluntarioArea {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  voluntarios Voluntario[]
}

model Voluntario {
  id         Int             @id @default(autoincrement())
  nome       String
  areaId     Int
  area       VoluntarioArea  @relation(fields: [areaId], references: [id])
  dons       String?
  telefone   String
  email      String?
  disponivel Boolean         @default(true)
  criadoEm   DateTime        @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  senha     String
  telefone  String?  // <-- COMENTE OU REMOVA ESTA LINHA TEMPORARIAMENTE
  aprovado  Boolean  @default(false)
  admin     Boolean  @default(false)
  criadoEm  DateTime @default(now())
 
}