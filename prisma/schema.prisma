generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Aviso {
  id         Int      @id @default(autoincrement())
  titulo     String
  descricao  String?
  imagemUrl  String
  dataInicio DateTime
  dataFim    DateTime
  ordem      Int      @default(0)
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Membro {
  id             Int      @id @default(autoincrement())
  nome           String
  dataNascimento DateTime
  fotoUrl        String?
  ativo          Boolean  @default(true)
  criadoEm      DateTime @default(now())
}

model servico {
  id        Int      @id @default(autoincrement())
  nome      String   // nome da pessoa ou empresa
  tipo      String   // ex: cabeleireiro, pintor, eletricista
  descricao String?  // descrição opcional do serviço
  telefone  String   // telefone ou WhatsApp
  criadoEm  DateTime @default(now())
}